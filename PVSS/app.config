<startup><supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.5" /></startup>
    <userSettings>
        <PVSS.Properties.Settings>
            <setting name="COMPort" serializeAs="String">
                <value>COM4</value>
            </setting>
            <setting name="BaudRate" serializeAs="String">
                <value>115200</value>
            </setting>
            <setting name="CompanyText" serializeAs="String">
                <value>ISPTEL, Lda</value>
            </setting>
            <setting name="JobNameText" serializeAs="String">
                <value>MV Vessel IWS</value>
            </setting>
            <setting name="DiverNameText" serializeAs="String">
                <value>Diver Name</value>
            </setting>
            <setting name="IsHDCameraChecked" serializeAs="String">
                <value>False</value>
            </setting>
            <setting name="IsSDCameraChecked" serializeAs="String">
                <value>True</value>
            </setting>
            <setting name="IsInterpolatedChecked" serializeAs="String">
                <value>True</value>
            </setting>
        </PVSS.Properties.Settings>
    </userSettings>
