<Window x:Class="PVSS.SplashScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PVSS PRO DUO" Height="400" Width="660"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize" Topmost="True"
        x:Name="SplashWindow">

    <Window.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetName="RootGrid"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.6"/>
        </Storyboard>
        <Storyboard x:Key="PulseBar" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="GlowRect"
                             Storyboard.TargetProperty="Opacity"
                             From="0.3" To="1.0"
                             Duration="0:0:0.8" AutoReverse="True"/>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource FadeIn}"/>
            <BeginStoryboard Storyboard="{StaticResource PulseBar}"/>
        </EventTrigger>
    </Window.Triggers>

    <Border CornerRadius="12" Background="Transparent">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="4" Opacity="0.65"/>
        </Border.Effect>

        <Grid x:Name="RootGrid" Opacity="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Border CornerRadius="12" Background="#0D2035" Margin="0,45,0,0"/>

            <Grid Margin="0,45,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <!-- logo -->
                    <RowDefinition Height="Auto"/>
                    <!-- product label -->
                    <RowDefinition Height="Auto"/>
                    <!-- divider -->
                    <RowDefinition Height="Auto"/>
                    <!-- progress -->
                    <RowDefinition Height="Auto"/>
                    <!-- checklist -->
                    <RowDefinition Height="Auto"/>
                    <!-- status -->
                    <RowDefinition Height="Auto"/>
                    <!-- drive warning -->
                    <RowDefinition Height="14"/>
                    <!-- bottom pad -->
                </Grid.RowDefinitions>

                <!-- ===== LOGO — large, centred ===== -->
                <Image
                       Source="/PVSS;component/Design/isptel_logo.JPG"
                       Height="125" Stretch="Uniform"
                       HorizontalAlignment="Center" VerticalAlignment="Top" Width="310" Margin="0,39,0,0"/>

                <!-- ===== PRODUCT NAME + SUBTITLE ===== -->
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,14">
                    <TextBlock Text="PVSS PRO DUO  6.21"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#7BA8CC" FontFamily="Segoe UI"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Professional Underwater Video System"
                               FontSize="9.5" Foreground="#7BA8CC"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"
                               Margin="0,3,0,0"/>
                </StackPanel>

                <!-- ===== DIVIDER ===== -->
                <Rectangle Grid.Row="2" Height="1" Fill="#1E3F5A" Margin="28,0,28,10"/>

                <!-- ===== PROGRESS BAR ===== -->
                <Grid Grid.Row="3" Margin="32,0,32,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="StepLabel" Text="Initialising..."
                               FontSize="10" Foreground="#7BA8CC" FontFamily="Segoe UI"
                               Grid.Column="0"/>
                    <TextBlock x:Name="PercentLabel" Text="0 %"
                               FontSize="10" Foreground="#7BA8CC" FontFamily="Segoe UI"
                               Grid.Column="1"/>
                </Grid>
                <Border Grid.Row="3" CornerRadius="5" Background="#1A3550"
                        Height="10" Margin="32,20,32,0">
                    <Border x:Name="ProgressFill" CornerRadius="5"
                            Background="#1E6FA8"
                            HorizontalAlignment="Left" Width="0">
                        <Rectangle x:Name="GlowRect" Fill="White" Opacity="0.3" RadiusX="5" RadiusY="5"/>
                    </Border>
                </Border>

                <!-- ===== CHECKLIST ===== -->
                <ItemsControl x:Name="CheckList" Grid.Row="4" Margin="32,8,32,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,1,14,1">
                                <TextBlock Text="{Binding Icon}" FontSize="9"
                                           Foreground="{Binding ItemColor}" Margin="0,0,3,0"/>
                                <TextBlock Text="{Binding Label}" FontSize="9"
                                           Foreground="{Binding ItemColor}" FontFamily="Segoe UI"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ===== STATUS TEXT ===== -->
                <TextBlock x:Name="StatusText" Grid.Row="5"
                           Text="Please wait..."
                           FontSize="9.5" Foreground="#4A7A9B"
                           FontFamily="Segoe UI" FontStyle="Italic"
                           HorizontalAlignment="Center"
                           Margin="0,6,0,0"/>

                <!-- ===== DRIVE WARNING ===== -->
                <TextBlock x:Name="DriveWarningText" Grid.Row="6"
                           Text=""
                           FontSize="10" Foreground="#FF4444"
                           FontFamily="Segoe UI" FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center"
                           Margin="16,4,16,0"
                           Visibility="Collapsed"/>
            </Grid>

            <!-- Version watermark -->
            <TextBlock Text="v6.21  © 2026 ISPTEL"
                       FontSize="8" Foreground="#7BA8CC" FontFamily="Segoe UI"
                       VerticalAlignment="Bottom" HorizontalAlignment="Right"
                       Margin="0,0,12,6"/>
        </Grid>
    </Border>
</Window>
