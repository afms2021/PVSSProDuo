<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity" 
    xmlns:ei="http://schemas.microsoft.com/expression/2010/interactions"
	xmlns:ToggleSwitch="clr-namespace:ToggleSwitch;assembly=ToggleSwitch"
    xmlns:DateTime="clr-namespace:PVSS.Helpers"
    xmlns:Custom="http://www.galasoft.ch/mvvmlight"
    xmlns:oxy="clr-namespace:OxyPlot.Wpf;assembly=OxyPlot.Wpf"
    xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
    xmlns:Controls="clr-namespace:WPFMediaKit.DirectShow.Controls;assembly=WPFMediaKit"
    
    x:Class="PVSS.MainWindow" 
        mc:Ignorable="d"
        Title="ISPTEL - PVSS 6.0"
        Width="{x:Static SystemParameters.PrimaryScreenWidth}"
        Height="{x:Static SystemParameters.PrimaryScreenHeight}"
        Background="Gray" WindowStyle="None" d:DesignWidth="1920" d:DesignHeight="1080" WindowStartupLocation="Manual" KeyUp="Window_KeyUp" AllowsTransparency="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Skins/MainSkin.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <DateTime:NotifyingDateTime x:Key="NotifyingDateTimeDataSource" d:IsDataSource="True"/>
            <SolidColorBrush x:Key="TabControlNormalBorderBrush" Color="#8C8E94"/>
            <ControlTemplate x:Key="TabItemControlTemplate1" TargetType="{x:Type TabItem}">
                <Grid SnapsToDevicePixels="True">
                    <Border x:Name="Bd" BorderBrush="{TemplateBinding BorderBrush}" CornerRadius="6,6,0,0" BorderThickness="1,1,1,0" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter x:Name="Content" ContentTemplate="{TemplateBinding HeaderTemplate}" Content="{TemplateBinding Header}" ContentStringFormat="{TemplateBinding HeaderStringFormat}" ContentSource="Header" HorizontalAlignment="{Binding HorizontalContentAlignment, RelativeSource={RelativeSource FindAncestor, AncestorLevel=1, AncestorType={x:Type ItemsControl}}}" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="{Binding VerticalContentAlignment, RelativeSource={RelativeSource FindAncestor, AncestorLevel=1, AncestorType={x:Type ItemsControl}}}"/>
                    </Border>
                </Grid>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" TargetName="Bd">
                            <Setter.Value>
                                <LinearGradientBrush EndPoint="0,1" StartPoint="0,0">
                                    <GradientStop Color="#FFEAF6FD" Offset="0.15"/>
                                    <GradientStop Color="#FFD9F0FC" Offset="0.5"/>
                                    <GradientStop Color="#FFBEE6FD" Offset="0.5"/>
                                    <GradientStop Color="#FFA7D9F5" Offset="1"/>
                                </LinearGradientBrush>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Panel.ZIndex" Value="1"/>
                        <Setter Property="Background" TargetName="Bd" Value="#FF005E93"/>
                    </Trigger>
                    <MultiTrigger>
                        <MultiTrigger.Conditions>
                            <Condition Property="IsSelected" Value="False"/>
                            <Condition Property="IsMouseOver" Value="True"/>
                        </MultiTrigger.Conditions>
                        <Setter Property="BorderBrush" TargetName="Bd" Value="#FF3C7FB1"/>
                    </MultiTrigger>
                    <Trigger Property="TabStripPlacement" Value="Bottom">
                        <Setter Property="BorderThickness" TargetName="Bd" Value="1,0,1,1"/>
                    </Trigger>
                    <Trigger Property="TabStripPlacement" Value="Left">
                        <Setter Property="BorderThickness" TargetName="Bd" Value="1,1,0,1"/>
                    </Trigger>
                    <Trigger Property="TabStripPlacement" Value="Right">
                        <Setter Property="BorderThickness" TargetName="Bd" Value="0,1,1,1"/>
                    </Trigger>
                    <MultiTrigger>
                        <MultiTrigger.Conditions>
                            <Condition Property="IsSelected" Value="True"/>
                            <Condition Property="TabStripPlacement" Value="Top"/>
                        </MultiTrigger.Conditions>
                        <Setter Property="Margin" Value="-2,-2,-2,-1"/>
                        <Setter Property="Margin" TargetName="Content" Value="0,0,0,1"/>
                    </MultiTrigger>
                    <MultiTrigger>
                        <MultiTrigger.Conditions>
                            <Condition Property="IsSelected" Value="True"/>
                            <Condition Property="TabStripPlacement" Value="Bottom"/>
                        </MultiTrigger.Conditions>
                        <Setter Property="Margin" Value="-2,-1,-2,-2"/>
                        <Setter Property="Margin" TargetName="Content" Value="0,1,0,0"/>
                    </MultiTrigger>
                    <MultiTrigger>
                        <MultiTrigger.Conditions>
                            <Condition Property="IsSelected" Value="True"/>
                            <Condition Property="TabStripPlacement" Value="Left"/>
                        </MultiTrigger.Conditions>
                        <Setter Property="Margin" Value="-2,-2,-1,-2"/>
                        <Setter Property="Margin" TargetName="Content" Value="0,0,1,0"/>
                    </MultiTrigger>
                    <MultiTrigger>
                        <MultiTrigger.Conditions>
                            <Condition Property="IsSelected" Value="True"/>
                            <Condition Property="TabStripPlacement" Value="Right"/>
                        </MultiTrigger.Conditions>
                        <Setter Property="Margin" Value="-1,-2,-2,-2"/>
                        <Setter Property="Margin" TargetName="Content" Value="1,0,0,0"/>
                    </MultiTrigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Background" TargetName="Bd" Value="#FFF4F4F4"/>
                        <Setter Property="BorderBrush" TargetName="Bd" Value="#FFC9C7BA"/>
                        <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

        </ResourceDictionary>
    </Window.Resources>

    <Window.DataContext>
        <Binding Path="Main" Source="{StaticResource Locator}"/>
    </Window.DataContext>

    <Grid x:Name="LayoutRoot" Background="#FF333333" ScrollViewer.VerticalScrollBarVisibility="Disabled" Margin="0,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="1080"/>
        </Grid.RowDefinitions>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="VisibilityPopup">
                <VisualState x:Name="Visible">
                    <Storyboard>
                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Visibility)" Storyboard.TargetName="grid">
                            <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                        </ObjectAnimationUsingKeyFrames>
                    </Storyboard>
                </VisualState>
                <VisualState x:Name="Invisible">
                    <Storyboard>
                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Visibility)" Storyboard.TargetName="grid">
                            <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Hidden}"/>
                        </ObjectAnimationUsingKeyFrames>
                    </Storyboard>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1920"/>
        </Grid.ColumnDefinitions>
        <Grid Height="48" Margin="13,0,0,308" VerticalAlignment="Bottom" IsEnabled="{Binding SuppressEditing}" HorizontalAlignment="Left" Width="147">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.726*"/>
                <ColumnDefinition Width="0.274*"/>
            </Grid.ColumnDefinitions>
            <ProgressBar Margin="4.172,0,11.58,5" Value="{Binding BatteryPercentage}" Height="36.707" VerticalAlignment="Bottom" Foreground="{Binding BatteryColor}" Grid.ColumnSpan="2" SmallChange="1">
                <ProgressBar.Background>
                    <LinearGradientBrush EndPoint="1,0" StartPoint="0,0">
                        <GradientStop Color="#FFBABABA" Offset="0"/>
                        <GradientStop Color="#FFC7C7C7" Offset="0.5"/>
                        <GradientStop Color="#85000000" Offset="1"/>
                    </LinearGradientBrush>
                </ProgressBar.Background>
            </ProgressBar>
            <TextBlock Margin="0,16.771,0,15.308" TextWrapping="Wrap" Foreground="Black" Text="{Binding BatteryStatus, StringFormat=\{0:F1\} V}" TextAlignment="Center" d:LayoutOverrides="Height" Grid.ColumnSpan="2" FontSize="13.333"/>
            <Rectangle Fill="#FFF4F4F5" HorizontalAlignment="Right" Margin="0,16.771,4.997,14.967" Stroke="#FF909090" Width="6.583" Grid.Column="1"/>
        </Grid>
        <Grid Margin="344,0,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1520"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="1070"/>
            </Grid.RowDefinitions>
            <Controls:VideoCaptureElement x:Name="videoElement" VideoCaptureDevice="{Binding Video, Mode=OneWay}" DesiredPixelWidth="640" DesiredPixelHeight="480" Volume="100"  FPS="25" RenderTransformOrigin="0,0" IsManipulationEnabled="True" Margin="10,16,-24,16"/>
            <oxy:Plot x:Name="plot2" Model="{Binding MyPlotModel2}" Height="Auto" Margin="59,604,301,48" Width="Auto" Background="{x:Null}" Foreground="{x:Null}" Visibility="Hidden"/>
            <Grid x:Name="grid" Height="82" VerticalAlignment="Center" Margin="185,0,185,0" Background="#80333333" Visibility="Hidden">
                <Grid.Style>
                    <Style>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding OSDPopupVisibility}" Value="True" />
                                    <Condition Binding="{Binding Path=Visibility, ElementName=grid}" Value="Visible" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="FocusManager.FocusedElement" Value="{Binding ElementName=OSDLine}"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <i:Interaction.Behaviors>
                    <ei:DataStateBehavior Binding="{Binding OSDPopupVisibility}" Value="True" TrueState="Visible" FalseState="Invisible"/>
                </i:Interaction.Behaviors>
                <TextBlock TextWrapping="Wrap" VerticalAlignment="Top" Foreground="White" FontFamily="Segoe UI Light" FontSize="18" Margin="19,19,0,0" HorizontalAlignment="Left" ><Run Language="en-us" Text="Text:"/></TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="White" FontFamily="Segoe UI Light" FontSize="18" Margin="0,0,0,8" VerticalAlignment="Bottom" d:LayoutOverrides="Width" HorizontalAlignment="Center" ><Run Language="en-us" Text="Press ENTER to submit, F5 to cancel"/></TextBlock>
                <TextBox x:Name="OSDLine" TextWrapping="Wrap" Text="{Binding OSDLine1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Top" Margin="68,19,22,0" MaxLength="40" FontSize="18" />
            </Grid>
        </Grid>

        <TextBlock TextWrapping="Wrap" VerticalAlignment="Top" Foreground="White" FontFamily="Segoe UI Light" FontSize="18.667" Margin="118,263,1583,0" Text="{Binding StatusMessage}" Height="25" />
        <ToggleSwitch:HorizontalToggleSwitch HorizontalAlignment="Left" Margin="13,264,0,0" VerticalAlignment="Top" IsChecked="{Binding IsRecording, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
            <i:Interaction.Triggers>
                <ei:PropertyChangedTrigger Binding="{Binding IsRecording}">
                    <Custom:EventToCommand Command="{Binding ExecuteStartOrStopRecording, Mode=OneWay}"/>
                </ei:PropertyChangedTrigger>
            </i:Interaction.Triggers>
        </ToggleSwitch:HorizontalToggleSwitch>
        <Grid Background="#FF333330" Height="112" Margin="8,32,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Width="301" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <TextBlock TextWrapping="Wrap" Foreground="White" FontFamily="Segoe UI Light" FontSize="20" HorizontalAlignment="Left" Width="312" Margin="8,75,0,0" Height="32" VerticalAlignment="Top" Text="{Binding MaxDepthString}"/>
            <TextBlock TextWrapping="Wrap" Foreground="White" FontFamily="Segoe UI Light" FontSize="48" HorizontalAlignment="Left" Width="312" TextAlignment="Center" Margin="9.768,0,0,0" VerticalAlignment="Top" Text="{Binding DepthString}"/>
            <TextBlock TextWrapping="Wrap" VerticalAlignment="Bottom" FontFamily="Segoe UI Light" FontSize="14" Margin="96,0,0,5" Text="{Binding DepthSensorStatusText}" Foreground="{Binding DepthSensorMessageColor}" TextAlignment="Right" Height="27" />
        </Grid>
        <TextBlock TextWrapping="Wrap" VerticalAlignment="Top" Foreground="White" FontFamily="Segoe UI Light" FontSize="18.667" Margin="8,2,0,0" HorizontalAlignment="Left" Text="Diver 1 Actual Depth" Height="24" Width="246"/>
        <Grid Background="#FF333333" Height="72" Margin="8,174,1591,0" VerticalAlignment="Top" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*"/>
                <ColumnDefinition Width="23*"/>
            </Grid.ColumnDefinitions>
            <TextBlock TextWrapping="Wrap" Foreground="White" FontFamily="Segoe UI Light" FontSize="48" HorizontalAlignment="Left" Width="330" TextAlignment="Center" VerticalAlignment="Top" Text="{Binding DiveTime, StringFormat=hh\\:mm\\:ss}" Height="72" Margin="0,-1,0,0" Grid.ColumnSpan="2"/>
        </Grid>
        <TextBlock TextWrapping="Wrap" Foreground="White" FontFamily="Segoe UI Light" FontSize="18.667" Margin="8,144,0,0" HorizontalAlignment="Left" Text="Diver 1 Total Dive Time" VerticalAlignment="Top" Height="25" Width="207"/>
        <Image HorizontalAlignment="Left" Height="25" Margin="121,318,0,0" Source="Design/Video Camera.png" Stretch="Fill" VerticalAlignment="Top" Width="25"/>
        <TextBlock TextWrapping="Wrap" VerticalAlignment="Top" Foreground="White" FontFamily="Segoe UI Light" FontSize="18.667" Margin="160,318,0,0" Text="Camera - F1" HorizontalAlignment="Left" Height="25" Width="110"/>
        <TextBlock TextWrapping="Wrap" VerticalAlignment="Top" Foreground="White" FontFamily="Segoe UI Light" FontSize="18.667" Margin="160,352,0,0" HorizontalAlignment="Left" Height="25" Width="94"><Run Language="pt-pt" Text="Light - F9"/></TextBlock>
        <Image Height="25" Width="25" Margin="121,352,1774,0" Source="Design/Light Bulb.png" Stretch="Fill" VerticalAlignment="Top" RenderTransformOrigin="0.24,0.92"/>
        <ToggleSwitch:HorizontalToggleSwitch HorizontalAlignment="Left" Margin="13,318,0,0" VerticalAlignment="Top" IsChecked="{Binding IsCameraOn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
            <i:Interaction.Triggers>
                <ei:PropertyChangedTrigger Binding="{Binding IsCameraOn}">
                    <Custom:EventToCommand Command="{Binding ChangeCameraState, Mode=OneWay}"/>
                </ei:PropertyChangedTrigger>
            </i:Interaction.Triggers>
        </ToggleSwitch:HorizontalToggleSwitch>
        <ToggleSwitch:HorizontalToggleSwitch HorizontalAlignment="Left" Margin="13,352,0,0" VerticalAlignment="Top" IsChecked="{Binding IsLightOn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
            <i:Interaction.Triggers>
                <ei:PropertyChangedTrigger Binding="{Binding IsLightOn}">
                    <Custom:EventToCommand Command="{Binding ChangeLightState, Mode=OneWay}"/>
                </ei:PropertyChangedTrigger>
            </i:Interaction.Triggers>
        </ToggleSwitch:HorizontalToggleSwitch>
        <TextBlock Margin="13,0,0,360" TextWrapping="Wrap" VerticalAlignment="Bottom" FontFamily="Segoe UI Light" Foreground="White" HorizontalAlignment="Left" Width="72" Height="16"><Run Language="pt-pt" Text="Battery:"/></TextBlock>
        <TabControl Height="303" VerticalAlignment="Bottom" Background="Gray" BorderBrush="#008C8E94" Margin="0,0,0,5" HorizontalAlignment="Left" Width="319">
            <TabItem Header="Snapshot" BorderBrush="#00005E93" Background="Gray" Margin="0" Foreground="White" IsSelected="True" FocusVisualStyle="{DynamicResource SimpleButtonFocusVisual}" FontSize="14" Template="{DynamicResource TabItemControlTemplate1}">
                <Grid Background="#FF333333" Height="267" Margin="1,1,1,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="302"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text=" Take a snapshot (F7) to see the preview here." VerticalAlignment="Center" HorizontalAlignment="Left" Background="#FF333333" Foreground="White" Margin="16,0,0,0" Width="284" Height="26"/>
                    <Image Source="{Binding LastSnapshotImage}" MouseLeftButtonUp="Image_MouseLeftButtonUp" Cursor="Hand" Width="306" HorizontalAlignment="left" Margin="3,3,3,3"/>
                </Grid>
            </TabItem>
            <TabItem Header="Chart" BorderBrush="#00005E93" Background="Gray" Margin="0" Foreground="White" FontSize="14" Template="{DynamicResource TabItemControlTemplate1}">
                <Grid Background="#FF1373A9">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <oxy:Plot x:Name="plot1" Model="{Binding MyPlotModel}" Background="#FF333333" Foreground="White" TextColor="White" PlotAreaBorderColor="White"/>
                    <Image Height="30" Margin="10,0,0,10" Source="Design/Save.png" Stretch="Fill" VerticalAlignment="Bottom" Width="30" Cursor="Hand" HorizontalAlignment="Left" MouseLeftButtonUp="Image_MouseLeftButtonUp_1"/>
                </Grid>
            </TabItem>
            <TabItem Header="Video" BorderBrush="#00005E93" Background="Gray" Foreground="White" FontSize="14" Template="{DynamicResource TabItemControlTemplate1}" HorizontalAlignment="Left" Width="51" Margin="0,0,0,0">
                <Grid Background="#FF333333">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Grid Margin="3,0,0,0">
                        <Grid Height="80" Margin="0,0,160,22" VerticalAlignment="Bottom" Background="#FF333333">
                            <TextBlock HorizontalAlignment="Left" Margin="26,2,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontFamily="Segoe UI Light" Foreground="White" Text="Brightness" FontSize="10"/>
                            <TextBlock HorizontalAlignment="Left" Margin="26,18,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontFamily="Segoe UI Light" Foreground="White" Text="Contrast" FontSize="10"/>
                            <TextBlock HorizontalAlignment="Left" Margin="26,4,2,32" TextWrapping="Wrap" VerticalAlignment="Bottom" FontFamily="Segoe UI Light" Foreground="White" Text="Saturation" FontSize="10"/>
                            <TextBlock HorizontalAlignment="Left" Margin="26,0,0,7" TextWrapping="Wrap" VerticalAlignment="Bottom" FontFamily="Segoe UI Light" Foreground="White" Text="Hue" FontSize="10" Visibility="Hidden"/>
                            <Slider Height="14" Style="{DynamicResource SimpleSlider}" Value="{Binding HueValue}" Maximum="255" SmallChange="1" Visibility="Hidden"/>
                            <Slider Height="14" Style="{DynamicResource SimpleSlider}" Value="{Binding SaturationValue}" Maximum="255" SmallChange="1" Margin="80,37,10,29"/>
                            <Slider Height="14" Style="{DynamicResource SimpleSlider}" Value="{Binding ContrastValue}" Maximum="255" SmallChange="1" Margin="80,20,10,46"/>
                            <Slider Height="14" Style="{DynamicResource SimpleSlider}" Value="{Binding BrightnessValue}" Maximum="255" SmallChange="1" Margin="80,4,10,62"/>
                            <Image HorizontalAlignment="Left" Source="Design/Brightness.png" Stretch="Fill" Width="25" Height="25" VerticalAlignment="Top" d:LayoutOverrides="Height" Margin="0,-2,0,0"/>
                            <Image HorizontalAlignment="Left" Margin="2.486,0,0,26" Source="Design/Chrome.png" Stretch="Fill" Width="20" Height="20" VerticalAlignment="Bottom"/>
                            <Image HorizontalAlignment="Left" Margin="2.319,11,0,36.529" Source="Design/Contrast.png" Stretch="Fill" Width="20" Height="20"/>
                        </Grid>
                        <TextBlock HorizontalAlignment="Left" Margin="3,0,0,104" TextWrapping="Wrap" VerticalAlignment="Bottom" Foreground="White" FontSize="10" FontWeight="Bold" Width="41" RenderTransformOrigin="0.195,0.248"><Run Language="pt-pt" Text="Levels:"/></TextBlock>
                        <Grid Height="36" Margin="0,0,76,62" VerticalAlignment="Bottom" Background="#FF333333" HorizontalAlignment="Right" Width="80">
                            <RadioButton Content="  PAL" Margin="8,2,0,0" IsEnabled="{Binding SuppressEditing}" Style="{DynamicResource SimpleRadioButton}" VerticalAlignment="Top" Foreground="White" FontFamily="Segoe UI Light" FontSize="10" GroupName="VideoSystem" IsChecked="{Binding IsPALChecked}" HorizontalAlignment="Left"/>
                            <RadioButton Content="  NTSC" Margin="8,20,0,0" IsEnabled="{Binding SuppressEditing}" Style="{DynamicResource SimpleRadioButton}" VerticalAlignment="Top" Foreground="White" FontFamily="Segoe UI Light" FontSize="10" GroupName="VideoSystem" HorizontalAlignment="Left" IsChecked="{Binding IsNTSCChecked}"/>
                        </Grid>
                        <TextBlock Margin="0,0,78,101" TextWrapping="Wrap" VerticalAlignment="Bottom" Foreground="White" Text="Video System:" HorizontalAlignment="Right" Width="78" Height="16" FontSize="10" FontWeight="Bold" RenderTransformOrigin="0.128,0.438"/>
                        <TextBlock Margin="0,0,235,29" TextWrapping="Wrap" VerticalAlignment="Bottom" Foreground="White" HorizontalAlignment="Right" Width="72" FontSize="10" FontWeight="Bold" RenderTransformOrigin="0.514,2.729"><Run Language="pt-pt" Text="Audio Gain:"/></TextBlock>
                        <Grid Height="24" Margin="0,0,162,0" VerticalAlignment="Bottom" Background="#FF333333" HorizontalAlignment="Right" Width="145">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Slider Style="{DynamicResource SimpleSlider}" RenderTransformOrigin="0.5,0.5" HorizontalAlignment="Left" Width="90" Margin="0,1,0,0" VerticalAlignment="Top" LargeChange="5" Maximum="127" SmallChange="1" Value="{Binding AudioGainValue}" Height="14"/>
                            <CheckBox Content="AGC" HorizontalAlignment="Left"  VerticalAlignment="Top" Background="#FFF4F4F4" Foreground="White" FontFamily="Segoe UI Light" FontSize="10" IsChecked="{Binding AGC, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" RenderTransformOrigin="1.078,0.533" Height="16" Width="42" Margin="95,0,0,0"/>
                        </Grid>
                        <Grid Margin="3,20,76,117" Background="#FF333333">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock HorizontalAlignment="Left" Margin="26,7,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontFamily="Segoe UI Light" Foreground="White" FontSize="12" Width="62" Height="19"><Run Text="   Company"/><Run Text=":"/></TextBlock>
                            <TextBox x:Name="CompanyBox" IsEnabled="{Binding SuppressEditing}" Height="20" Margin="93,7,0,0" TextWrapping="WrapWithOverflow" Text="{Binding OSDLine2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Top" Background="#FF333333" BorderBrush="White" Foreground="White" FontFamily="Segoe UI Light" FontSize="12" MaxLength="15" MaxLines="1" HorizontalAlignment="Left" Width="106" />
                            <CheckBox Margin="93,112,0,0" Style="{DynamicResource SimpleCheckBox}" Foreground="White" FontFamily="Segoe UI Light" IsChecked="{Binding ShowTime}" Height="16" VerticalAlignment="Top" FontSize="10" Content="  Time" HorizontalAlignment="Left" RenderTransformOrigin="1.752,0.521"/>
                            <CheckBox Margin="161,112,0,0" Style="{DynamicResource SimpleCheckBox}" Foreground="White" FontFamily="Segoe UI Light" IsChecked="{Binding ShowDate}" Height="16" VerticalAlignment="Top" FontSize="10" Content="  Date" HorizontalAlignment="Left"/>
                            <Slider Height="16" Margin="112,84,34,0" Style="{DynamicResource SimpleSlider}" VerticalAlignment="Top" Value="{Binding OSDOffsetX}" Maximum="500" SmallChange="1" Visibility="Hidden"/>
                            <Slider Margin="0,37,-16,0" Style="{DynamicResource SimpleSlider}" Value="{Binding OSDOffsetY}" Maximum="450" SmallChange="1" RenderTransformOrigin="0.5,0.5" HorizontalAlignment="Right" Width="74" Height="16" VerticalAlignment="Top" Visibility="Hidden">
                                <Slider.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform/>
                                        <SkewTransform/>
                                        <RotateTransform Angle="90"/>
                                        <TranslateTransform/>
                                    </TransformGroup>
                                </Slider.RenderTransform>
                            </Slider>
                            <TextBlock HorizontalAlignment="Left" Margin="100,85,0,0" TextWrapping="Wrap" FontFamily="Segoe UI Light" Foreground="White" FontSize="10" VerticalAlignment="Top" Width="9" Visibility="Hidden"><Run Language="pt-pt" Text="X&#x9;"/></TextBlock>
                            <TextBlock HorizontalAlignment="Right" Margin="0,85,18,0" TextWrapping="Wrap" FontFamily="Segoe UI Light" Foreground="White" FontSize="10" VerticalAlignment="Top" Visibility="Hidden"><Run Language="pt-pt" Text="Y"/></TextBlock>
                            <TextBlock HorizontalAlignment="Left" Margin="44,32,0,0" VerticalAlignment="Top" FontFamily="Segoe UI Light" Foreground="White" FontSize="12" Width="44" Height="19"><Run Text="    "/><Run Text="   Job"/><Run Text=":"/></TextBlock>
                            <TextBox x:Name="JobNameBox" IsEnabled="{Binding SuppressEditing}" Height="20" Margin="93,32,0,0" TextWrapping="WrapWithOverflow" VerticalAlignment="Top" Text="{Binding JobName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Background="#FF333333" BorderBrush="White" Foreground="White" FontFamily="Segoe UI Light" FontSize="12" MaxLength="15" MaxLines="1" HorizontalAlignment="Left" Width="106" />

                            <ComboBox HorizontalAlignment="Left" Margin="93,82,0,0" SelectedItem="{Binding TimerValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Top" Width="106" SelectedIndex="0" FontSize="12" FontFamily="Segoe WP Semibold">
                                <ListBoxItem Content="5" FontFamily="Segoe WP Semibold" FontSize="12"/>
                                <ListBoxItem Content="10" FontFamily="Segoe WP Semibold" FontSize="12"/>
                                <ListBoxItem Content="15" FontSize="12" FontFamily="Segoe WP Semibold"/>
                                <ListBoxItem Content="Always On" FontSize="12" FontFamily="Segoe WP Semibold"/>
                            </ComboBox>
                            <Label Content="Display Timer:" HorizontalAlignment="Left" Margin="10,79,0,0" VerticalAlignment="Top" Width="80" Height="25" FontSize="12" FontFamily="Segoe UI Light" Foreground="White"/>
                            <TextBox x:Name="DiverNameBox" IsEnabled="{Binding SuppressEditing}" Height="20" Margin="93,57,0,0" TextWrapping="WrapWithOverflow" VerticalAlignment="Top" Text="{Binding DiverName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Background="#FF333333" BorderBrush="White" Foreground="White" FontFamily="Segoe UI Light" FontSize="12" MaxLength="15" MaxLines="1" HorizontalAlignment="Left" Width="106" />
                            <TextBlock HorizontalAlignment="Left" Margin="10,58,0,0" VerticalAlignment="Top" FontFamily="Segoe UI Light" Foreground="White" FontSize="12" Width="78" Height="19"><Run Text="    "/><Run Text="Diver Name:"/></TextBlock>
