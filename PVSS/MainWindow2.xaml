                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding OSDPopupVisibility2}" Value="True" />
                                    <Condition Binding="{Binding Path=Visibility, ElementName=grid}" Value="Visible" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="FocusManager.FocusedElement" Value="{Binding RelativeSource={RelativeSource Mode=Self}}"/>
                                <Setter Property="FocusManager.FocusedElement" Value="{Binding ElementName=OSDLine2}"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <i:Interaction.Behaviors>
                    <ei:DataStateBehavior Binding="{Binding OSDPopupVisibility2}" Value="True" TrueState="Visible" FalseState="Invisible"/>
                </i:Interaction.Behaviors>
